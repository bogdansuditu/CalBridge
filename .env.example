# Server configuration
PORT=5000
NODE_ENV=development

# Database path (relative to backend for local prisma, or absolute for container)
DATABASE_URL="file:/app/data/chronos.db"

# JWT Secret for web application login session
JWT_SECRET="super-secret-jwt-key-change-me-in-production"

# Sync interval for remote .ics subscriptions in hours
SYNC_INTERVAL_HOURS=6

# Rate limiting for auth endpoints (15 mins window, max 10 requests)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=10
